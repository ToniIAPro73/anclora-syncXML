# ============================================================================
# Anclora SyncXML — Environment Variables Template
# ============================================================================
#
# This file is a TEMPLATE for development (.env.local).
# For Preview and Production, see docs/ENVIRONMENT_VARIABLES.md
#
# DO NOT commit secrets to this file or to version control.
# ============================================================================

# --- DATABASE (LOCAL DEVELOPMENT) ---
# Use local PostgreSQL or Neon dev instance
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/anclora_syncxml_dev"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/anclora_syncxml_dev"

# --- NEXT.JS / AUTH (LOCAL DEVELOPMENT) ---
# All localhost URLs for local testing
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# --- SESSIONS (LOCAL DEVELOPMENT) ---
# Generate with: openssl rand -base64 32
SESSION_SECRET="dev-secret-change-in-production"

# --- SYNCXML CORE SETTINGS ---
SYNCXML_APP_URL="http://localhost:3000"
SYNCXML_LOGIN_URL="http://localhost:3000/login"
SYNCXML_ADMIN_EMAIL="antonio@anclora.com"
SYNCXML_DISABLE_AUTH="false"
SYNCXML_LOCAL_DEMO="false"

# --- ADMIN ACCESS (LOCAL DEVELOPMENT) ---
# For local testing of admin access endpoint
SYNCXML_ADMIN_ACCESS_ENABLED="true"
SYNCXML_ADMIN_ACCESS_TOKEN="dev-token-change-in-production"
SYNCXML_ADMIN_ACCESS_ALLOWED_ENV="development,preview"
SYNCXML_ADMIN_ACCESS_REDIRECT="/app"
SYNCXML_ALLOW_ADMIN_ACCESS_IN_PRODUCTION="false"

# --- SES SETTINGS (LOCAL DEVELOPMENT) ---
# Use preproduction (pre) for testing, never "prod" locally
SYNCXML_SES_ENV="pre"
SYNCXML_SES_ENDPOINT=""
SYNCXML_SES_USERNAME=""
SYNCXML_SES_PASSWORD=""
SYNCXML_SES_LANDLORD_CODE=""
SYNCXML_SES_APPLICATION="Anclora SyncXML"
SYNCXML_SES_ALLOW_PRODUCTION_SEND="false"
SYNCXML_SES_ALLOW_INSECURE_TLS="false"

# --- ENCRYPTION (OPTIONAL) ---
SYNCXML_ENCRYPTION_KEY=""
SYNCXML_FILE_ENCRYPTION_KEY=""
SYNCXML_ENABLE_PERSISTENT_STORAGE="false"

# --- EMAIL (OPTIONAL) ---
# Only if pilot request emails are enabled
RESEND_API_KEY=""
RESEND_FROM="Anclora SyncXML <piloto@anclora.com>"
SYNCXML_PILOT_REQUEST_TO="antonio@anclora.com"

# --- INTEGRATIONS (OPTIONAL) ---
NEXUS_SYNCXML_WEBHOOK_URL=""
NEXUS_SYNCXML_WEBHOOK_SECRET=""
NEXUS_WEBHOOK_URL=""
NEXUS_INTERNAL_API_KEY=""
SYNCXML_INTERNAL_API_SECRET=""
CRON_SECRET=""

# --- EXTERNAL SERVICES (OPTIONAL) ---
BLOB_READ_WRITE_TOKEN=""
HERMES_WORKER_URL="https://hermes-content-worker.vercel.app"
HERMES_WORKER_API_KEY=""

# --- ADVANCED (LOCAL DEVELOPMENT) ---
NODE_OPTIONS="--use-system-ca"

# --- DOCUMENT INGESTION (OPTIONAL - LOCAL) ---
ENABLE_MINERU_PARSER="false"
MINERU_AGENT_INGEST_PATH="/home/toni/projects/agent-tooling/mineru/bin/mineru-agent-ingest.sh"
MINERU_DEFAULT_BACKEND="pipeline"
MINERU_OUTPUT_BASE="/home/toni/projects/agent-tooling/mineru/output"
MINERU_PARSE_TIMEOUT_MS="180000"
