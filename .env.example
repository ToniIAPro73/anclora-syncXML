# === CONTROLLED PILOT ACCESS ===
# See docs/VERCEL_PREVIEW_SETUP.md and docs/SES_ACCESS_CONTROL.md

# Controlled admin access mode (secret URL + strong token)
# Disabled by default. Never commit a real token.
# Format: https://<url>/api/internal/admin-access?token=<SYNCXML_ADMIN_ACCESS_TOKEN>
SYNCXML_ADMIN_ACCESS_ENABLED="false"
SYNCXML_ADMIN_ACCESS_TOKEN=""

# Allowed environments for admin access (comma-separated)
# Safe values: "development,preview"
# NEVER include "production" here
SYNCXML_ADMIN_ACCESS_ALLOWED_ENV="preview,development"

# Where to redirect after admin access
SYNCXML_ADMIN_ACCESS_REDIRECT="/app"

# CRITICAL: Allow admin access in production?
# ⚠️ MUST BE "false" for controlled pilot phase
# Only set to "true" if explicitly needed by technical owner
SYNCXML_ALLOW_ADMIN_ACCESS_IN_PRODUCTION="false"
NODE_OPTIONS="--use-system-ca"
SYNCXML_SES_ENV="pre"
SYNCXML_SES_ENDPOINT=""
SYNCXML_SES_USERNAME=""
SYNCXML_SES_PASSWORD=""
SYNCXML_SES_LANDLORD_CODE=""
SYNCXML_SES_APPLICATION="Anclora SyncXML"
SYNCXML_SES_ALLOW_PRODUCTION_SEND="false"
SYNCXML_SES_ALLOW_INSECURE_TLS="false"
