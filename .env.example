# Anclora SyncXML environment template.
# Copy values into .env.local for local development. Never commit real secrets.

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/anclora_syncxml_dev"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/anclora_syncxml_dev"
SYNCXML_ENABLE_PERSISTENT_STORAGE="false"

# App URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
SYNCXML_APP_URL="http://localhost:3000"
SYNCXML_LOGIN_URL="http://localhost:3000/login"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Auth and sessions
SESSION_SECRET="replace-with-openssl-rand-base64-32"
AUTH_SECRET="replace-with-different-compatible-secret-if-used"
SYNCXML_ADMIN_EMAIL="admin@example.com"
SYNCXML_ADMIN_PASSWORD="replace-with-local-admin-password"
SYNCXML_DISABLE_AUTH="false"
SYNCXML_LOCAL_DEMO="false"
SYNCXML_ALLOW_LEGACY_SECRET_COOKIE="false"

# Admin access endpoint
SYNCXML_ADMIN_ACCESS_ENABLED="false"
SYNCXML_ADMIN_ACCESS_TOKEN=""
SYNCXML_ADMIN_ACCESS_ALLOWED_ENV="development,preview"
SYNCXML_ADMIN_ACCESS_REDIRECT="/app"
SYNCXML_ALLOW_ADMIN_ACCESS_IN_PRODUCTION="false"

# Encryption
SYNCXML_ENCRYPTION_KEY=""
SYNCXML_FILE_ENCRYPTION_KEY=""

# Internal APIs and scheduled jobs
SYNCXML_INTERNAL_API_SECRET=""
CRON_SECRET=""

# Email / Resend
RESEND_API_KEY=""
RESEND_FROM="Anclora SyncXML <piloto@example.com>"
RESEND_FROM_EMAIL="Anclora SyncXML <piloto@example.com>"
RESEND_REPLY_TO=""
SYNCXML_PILOT_REQUEST_TO="admin@example.com"
SYNCXML_FEEDBACK_TO="antonio@anclora.com"
ADMIN_EMAILS="admin@example.com"

# Nexus / Hermes integrations
NEXUS_SYNCXML_WEBHOOK_URL=""
NEXUS_SYNCXML_WEBHOOK_SECRET=""
NEXUS_WEBHOOK_URL=""
NEXUS_INTERNAL_API_KEY=""
HERMES_WORKER_URL=""
HERMES_WORKER_API_KEY=""

# SES.HOSPEDAJES. Keep production sending disabled until preproduction evidence exists.
SYNCXML_SES_ENV="pre"
SYNCXML_SES_ENDPOINT=""
SYNCXML_SES_USERNAME=""
SYNCXML_SES_PASSWORD=""
SYNCXML_SES_LANDLORD_CODE=""
SYNCXML_SES_APPLICATION="Anclora SyncXML"
SYNCXML_SES_ALLOW_PRODUCTION_SEND="false"
SYNCXML_SES_ALLOW_INSECURE_TLS="false"

# Optional blob storage and document ingestion
BLOB_READ_WRITE_TOKEN=""
ENABLE_MINERU_PARSER="false"
MINERU_AGENT_INGEST_PATH=""
MINERU_DEFAULT_BACKEND="pipeline"
MINERU_OUTPUT_BASE=""
MINERU_PARSE_TIMEOUT_MS="180000"
